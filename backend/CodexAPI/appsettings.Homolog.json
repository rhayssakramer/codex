{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "codex-api",
    "Audience": "codex-app",
    "ExpirationHours": "24"
  },
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL_HOMOLOG}"
  },
  "CORS": {
    "AllowedOrigins": [
      "https://codex-homolog.vercel.app",
      "https://codex-preview.vercel.app"
    ]
  }
}
