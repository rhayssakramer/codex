{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "${Jwt__SecretKey}",
    "Issuer": "codex-api",
    "Audience": "codex-app",
    "ExpirationHours": "24"
  },
  "ConnectionStrings": {
    "DefaultConnection": "${NEON_DATABASE_URL}",
    "PostgresConnection": "${NEON_DATABASE_URL}"
  },
  "CORS": {
    "AllowedOrigins": [
      "https://codex-techy.vercel.app",
      "https://codexacademy.com.br",
      "https://www.codexacademy.com.br",
      "https://*.azurecontainerapps.io"
    ]
  },
  "Docker": {
    "Repository": "rhayssakramer/codex",
    "Registry": "docker.io"
  },
  "Azure": {
    "ContainerAppsEnvironment": "${AZURE_CONTAINER_APPS_ENVIRONMENT}",
    "ResourceGroup": "${AZURE_RESOURCE_GROUP}",
    "SubscriptionId": "${AZURE_SUBSCRIPTION_ID}"
  },
  "Frontend": {
    "Url": "https://codex.vercel.app"
  }
}
